# ---------------------------------------------------------------------------
# Dar Al Muneerah — environment configuration
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# Database ------------------------------------------------------------------
# Default: local SQLite (zero-config, works out of the box).
DATABASE_URL="file:./prisma/dev.db"
#
# For production (Supabase / PostgreSQL) switch the provider in
# prisma/schema.prisma to "postgresql" and use a URL such as:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?schema=public"

# Auth ----------------------------------------------------------------------
# Secret used to sign admin session JWTs. MUST be changed in production.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-in-production-please-abcdef123456"

# Seeded administrator account (created by `npm run db:seed`) ----------------
ADMIN_EMAIL="admin@darmuneerah.edu.pk"
ADMIN_PASSWORD="ChangeMe!2026"
ADMIN_NAME="Administrator"

# File uploads --------------------------------------------------------------
# Local directory (dev). In production use Supabase Storage (see README).
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="8"

# Public site config --------------------------------------------------------
NEXT_PUBLIC_SITE_NAME="Dar Al Muneerah"
NEXT_PUBLIC_FACEBOOK_URL="https://facebook.com/"
NEXT_PUBLIC_WHATSAPP_URL="https://whatsapp.com/channel/"
NEXT_PUBLIC_CONTACT_EMAIL="info@darmuneerah.edu.pk"
NEXT_PUBLIC_CONTACT_PHONE="+92 51 000 0000"

# Optional: Supabase (only if you wire the storage adapter) ------------------
# NEXT_PUBLIC_SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="uploads"
