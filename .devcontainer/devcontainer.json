{
  "name": "Dar Al Muneerah (Node 20)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {},
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": { "label": "Dar Al Muneerah", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "corepack enable && npm install && cp -n .env.example .env && npm run db:push && npm run db:seed",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
